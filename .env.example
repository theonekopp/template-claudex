# Reference template for ../secrets/assistant.env
#
# Secrets live OUTSIDE this repo in a sibling directory:
#   parent/
#     secrets/assistant.env   ← copy this file there and fill in your values
#     claudex/                ← this repo
#       .env.example          ← this file
#
# This keeps all credentials out of version control entirely.
# The launcher scripts (claudesafe.sh, codexsafe.sh, opencodesafe.sh)
# automatically source ../secrets/assistant.env before starting the agent.

# API keys for your CLI agent(s)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Add variables for any tools you create in /tools/
# MY_SERVICE_API_KEY=
# MY_SERVICE_BASE_URL=

# Web output layer (optional — only needed if using /optional/web/)
# AUTH_USER=
# AUTH_PASS=
